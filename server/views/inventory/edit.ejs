<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="/bootstrap-icons-1.10.5/font/bootstrap-icons.min.css" />
    <link href="/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/myStyle.css" />
    <title>Edit Item - Inventory</title>
</head>
<body>
    <main class="d-flex">
        <%- include('../Components/sidebar.ejs', { currentPage: "inventory", username: username }) %>
        <section class="w-100 p-4">
            <div class="d-flex align-items-center mb-4">
                <a href="/dashboard/inventory" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
                <h2 class="mb-0">Edit Item: <%= obj.itemName %></h2>
            </div>
            
            <form action="/dashboard/inventory/update/<%= obj._id %>" method="POST" class="row g-3 shadow p-4 mt-3 bg-body-tertiary rounded">
                <div class="col-md-6">
                    <label class="form-label">Item Name</label>
                    <input name="itemName" value="<%= obj.itemName %>" type="text" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Category</label>
                    <select name="category" class="form-select">
                        <option value="Paper" <%= obj.category === 'Paper' ? 'selected' : '' %>>Paper</option>
                        <option value="Ink" <%= obj.category === 'Ink' ? 'selected' : '' %>>Ink</option>
                        <option value="Hardware" <%= obj.category === 'Hardware' ? 'selected' : '' %>>Hardware</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Current Quantity</label>
                    <input name="quantity" value="<%= obj.quantity %>" type="number" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Min Alert Quantity</label>
                    <input name="minQuantity" value="<%= obj.minQuantity %>" type="number" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Unit</label>
                    <input name="unit" value="<%= obj.unit %>" type="text" class="form-control" required />
                </div>
                
                <div class="col-md-6">
                    <label class="form-label fw-bold">Cost Price (التكلفة)</label>
                    <input name="costPrice" value="<%= obj.costPrice %>" type="number" step="0.01" class="form-control border-danger text-danger" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Selling Price (البيع)</label>
                    <input name="sellingPrice" value="<%= obj.sellingPrice %>" type="number" step="0.01" class="form-control border-success text-success" required />
                </div>

                <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">Update Item Details</button>
                    <a href="/dashboard/inventory" class="btn btn-secondary px-4">Cancel</a>
                </div>
            </form>
        </section>
    </main>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>