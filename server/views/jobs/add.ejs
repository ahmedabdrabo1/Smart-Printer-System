<!DOCTYPE html>
<html lang="en" data-bs-theme="auto">
  <head>
    <script src="/js/color-modes.js"></script>
    <link rel="stylesheet" href="/bootstrap-icons-1.10.5/font/bootstrap-icons.min.css" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>New Print Job - Smart Printer</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/dark-light.css" />
    <link href="/css/sidebars.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/myStyle.css" />
  </head>
  <body>
    <%- include('../Components/dark-light.ejs') %>

    <main class="d-flex flex-nowrap">
      <%- include('../Components/sidebar.ejs', { currentPage: "jobs", username: username }) %>

      <section class="w-100">
        <%- include('../Components/navbar.ejs') %>

        <div class="container mt-4">
          <div class="d-flex align-items-center mb-4">
            <a href="/dashboard/jobs" class="btn btn-outline-secondary btn-sm me-3"><i class="bi bi-arrow-left"></i></a>
            <h2 class="mb-0">Record New Print Job</h2>
          </div>

          <div class="row justify-content-center">
            <div class="col-lg-8">
              <form action="/dashboard/jobs/add" method="POST" class="row g-3 shadow p-4 rounded bg-body-tertiary">
  
                <div class="col-md-12">
                  <label class="form-label">Customer Name</label>
                  <input name="customerName" type="text" class="form-control" placeholder="Optional: Customer Name" value="Guest" />
                </div>
              
                <div class="col-md-6">
                  <label class="form-label">Select Printer</label>
                  <select name="printer" class="form-select" required>
                    <option value="" disabled selected>Choose Printer...</option>
                    <% printers.forEach(printer => { %>
                      <option value="<%= printer._id %>"><%= printer.name %> (Counter: <%= printer.counter %>)</option>
                    <% }) %>
                  </select>
                </div>
              
                <div class="col-md-6">
                  <label class="form-label">Select Paper/Material</label>
                  <select name="itemUsed" id="itemUsed" class="form-select" onchange="calculateTotal()" required>
                    <option value="" data-price="0" disabled selected>Choose Material...</option>
                    <% inventory.forEach(item => { %>
                      <option value="<%= item._id %>" data-price="<%= item.sellingPrice || 0 %>" <%= item.quantity <= 0 ? 'disabled' : '' %>>
                        <%= item.itemName %> (<%= item.quantity %> <%= item.unit %> available)
                      </option>
                    <% }) %>
                  </select>
                </div>
              
                <div class="col-md-4">
                  <label class="form-label">Number of Pages (Counter)</label>
                  <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-files"></i></span>
                    <input name="pagesCount" type="number" class="form-control" placeholder="0" required min="1" />
                  </div>
                </div>
              
                <div class="col-md-4">
                  <label class="form-label">Actual Sheets Used</label>
                  <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-layers"></i></span>
                    <input name="sheetsUsed" id="sheetsUsed" type="number" class="form-control" placeholder="Actual sheets" required min="1" oninput="calculateTotal()" />
                  </div>
                </div>
              
                <div class="col-md-4">
                  <label class="form-label">Paper Type</label>
                  <select name="paperType" class="form-select" required>
                    <option value="Standard A4" selected>Standard A4</option>
                    <option value="Glossy">Glossy</option>
                    <option value="A3">A3</option>
                    <option value="Sticker">Sticker</option>
                  </select>
                </div>
              
                <div class="col-md-12">
                  <label class="form-label fw-bold text-success">Total Cash Charged</label>
                  <div class="input-group">
                    <span class="input-group-text">EGP</span>
                    <input name="totalPrice" id="totalPrice" type="number" step="0.01" class="form-control bg-light text-success fw-bold" placeholder="0.00" readonly required />
                  </div>
                </div>
              
                <div class="col-12 mt-4">
                  <button type="submit" class="btn btn-primary w-100 fs-5 py-2">
                    <i class="bi bi-check-circle me-2"></i> Submit and Print
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script src="/js/bootstrap.bundle.min.js"></script>
    <script src="/js/sidebars.js"></script>
    
    <script>
      function calculateTotal() {
          const itemDropdown = document.getElementById('itemUsed');
          const sheetsInput = document.getElementById('sheetsUsed');
          const totalInput = document.getElementById('totalPrice');

          // لو لسه مختارش ورق، خلي السعر صفر
          if (itemDropdown.selectedIndex === 0) {
              totalInput.value = "0.00";
              return;
          }

          // 1. جلب سعر الورقة الواحدة من العنصر المختار
          const selectedOption = itemDropdown.options[itemDropdown.selectedIndex];
          const unitPrice = parseFloat(selectedOption.getAttribute('data-price')) || 0;
          
          // 2. جلب عدد الورق المكتوب
          const sheetsCount = parseInt(sheetsInput.value) || 0;

          // 3. حساب الإجمالي وعرضه
          const total = unitPrice * sheetsCount;
          totalInput.value = total.toFixed(2);
      }
    </script>
  </body>
</html>