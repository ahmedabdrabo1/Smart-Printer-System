<!DOCTYPE html>
<html lang="en" data-bs-theme="auto">
  <head>
    <script src="/js/color-modes.js"></script>
    <link rel="stylesheet" href="/bootstrap-icons-1.10.5/font/bootstrap-icons.min.css" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Financial Report - Smart Printer</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/dark-light.css" />
    <link href="/css/sidebars.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/myStyle.css" />
    
    <style>
      /* تحسين شكل الجدول والبطاقات */
      .card { border-radius: 12px; transition: transform 0.2s; }
      .table thead th { background-color: #f8f9fa; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.5px; }
      
      /* تنسيقات الطباعة لتحويل الصفحة لتقرير رسمي عند التصدير */
      @media print {
        .sidebar, .navbar, .btn, .card-body form, #exportExcel, .dark-light-toggle {
          display: none !important;
        }
        main { display: block !important; }
        .container-fluid { width: 100% !important; padding: 0 !important; }
        .card { border: 1px solid #eee !important; box-shadow: none !important; margin-bottom: 20px !important; }
        body { background-color: white !important; }
      }
    </style>
  </head>
  <body>
    <%- include('../Components/dark-light.ejs') %>

    <main class="d-flex flex-nowrap">
      <%- include('../Components/sidebar.ejs', { currentPage: "financial", username: username }) %>

      <section class="w-100">
        <%- include('../Components/navbar.ejs') %>

        <div class="container-fluid mt-4 px-4">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
              <h2 class="mb-1">
                <i class="bi bi-cash-stack me-2 text-success"></i>Financial Reports
              </h2>
              <p class="text-muted small mb-0">
                Detailed overview of revenues, costs, and net profits.
              </p>
            </div>
            <div class="d-flex gap-2">
              <button onclick="window.print()" class="btn btn-outline-danger btn-sm">
                <i class="bi bi-file-earmark-pdf-fill me-1"></i> Export PDF
              </button>
              <button id="exportExcel" class="btn btn-outline-success btn-sm">
                <i class="bi bi-file-earmark-excel-fill me-1"></i> Export Excel
              </button>
            </div>
          </div>

          <div class="card shadow-sm border-0 mb-4 bg-light">
            <div class="card-body">
              <form action="/dashboard/financial/report" method="GET" class="row g-3 align-items-end">
                <div class="col-md-4">
                  <label class="form-label text-muted small fw-bold">From Date</label>
                  <input type="date" name="startDate" class="form-control" value="<%= filters.startDate || '' %>" />
                </div>
                <div class="col-md-4">
                  <label class="form-label text-muted small fw-bold">To Date</label>
                  <input type="date" name="endDate" class="form-control" value="<%= filters.endDate || '' %>" />
                </div>
                <div class="col-md-4 d-flex gap-2">
                  <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search me-1"></i> Analyze
                  </button>
                  <a href="/dashboard/financial/report" class="btn btn-outline-secondary w-100">Reset</a>
                </div>
              </form>
            </div>
          </div>

          <div class="row mb-4">
            <div class="col-md-4">
              <div class="card bg-primary text-white shadow-sm border-0">
                <div class="card-body p-4">
                  <div class="d-flex justify-content-between">
                    <div>
                      <h6 class="text-white-50">Total Revenue</h6>
                      <h2 class="fw-bold mb-0"><%= totalRevenue.toLocaleString() %> <small class="fs-6">EGP</small></h2>
                    </div>
                    <i class="bi bi-graph-up-arrow fs-1 opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="card bg-danger text-white shadow-sm border-0">
                <div class="card-body p-4">
                  <div class="d-flex justify-content-between">
                    <div>
                      <h6 class="text-white-50">Total Costs</h6>
                      <h2 class="fw-bold mb-0"><%= totalCost.toLocaleString() %> <small class="fs-6">EGP</small></h2>
                    </div>
                    <i class="bi bi-cart-dash fs-1 opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="card bg-success text-white shadow-sm border-0">
                <div class="card-body p-4">
                  <div class="d-flex justify-content-between">
                    <div>
                      <h6 class="text-white-50">Net Profit</h6>
                      <h2 class="fw-bold mb-0"><%= netProfit.toLocaleString() %> <small class="fs-6">EGP</small></h2>
                    </div>
                    <i class="bi bi-wallet2 fs-1 opacity-50"></i>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
              <h5 class="mb-0 text-dark fw-bold">Daily Profit Analysis</h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table id="financialTable" class="table table-hover text-center align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>Date</th>
                      <th>Revenue (Sales)</th>
                      <th>Daily Profit (Net)</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (dailyStats.length > 0) { %> 
                      <% dailyStats.forEach(stat => { %>
                      <tr>
                        <td class="fw-bold text-muted">
                          <%= moment(stat._id).format('DD MMM YYYY') %>
                        </td>
                        <td class="text-primary fw-bold">
                          <%= stat.dailyRevenue.toLocaleString() %> EGP
                        </td>
                        <td class="<%= stat.dailyProfit >= 0 ? 'text-success' : 'text-danger' %> fw-bold">
                          <%= stat.dailyProfit.toLocaleString() %> EGP
                        </td>
                        <td>
                          <% if (stat.dailyProfit >= 0) { %>
                            <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle">
                              <i class="bi bi-arrow-up-right me-1"></i> Profitable
                            </span>
                          <% } else { %>
                            <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle">
                              <i class="bi bi-arrow-down-right me-1"></i> Loss
                            </span>
                          <% } %>
                        </td>
                      </tr>
                      <% }) %> 
                    <% } else { %>
                      <tr>
                        <td colspan="4" class="py-5 text-muted text-center">
                          <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                          No transactions found for this period.
                        </td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script src="/js/bootstrap.bundle.min.js"></script>
    <script>
      // تحسين تصدير Excel ليدعم الحروف والعربي بشكل أفضل
      document.getElementById("exportExcel").addEventListener("click", function () {
        let table = document.getElementById("financialTable");
        let html = table.outerHTML;
        let url = 'data:application/vnd.ms-excel;charset=utf-8,' + encodeURIComponent(html);
        let link = document.createElement("a");
        link.download = "Financial_Report_<%= moment().format('YYYY-MM-DD') %>.xls";
        link.href = url;
        link.click();
      });
    </script>
  </body>
</html>