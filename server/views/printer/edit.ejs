<!DOCTYPE html>
<html lang="en" data-bs-theme="auto">
  <head>
    <script src="/js/color-modes.js"></script>
    <link
      rel="stylesheet"
      href="/bootstrap-icons-1.10.5/font/bootstrap-icons.min.css"
    />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Add Printer - Smart Printer</title>
    <link href="/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/dark-light.css" />
    <link href="/css/sidebars.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/myStyle.css" />
  </head>
  <body>
    <%- include('../Components/dark-light.ejs') %>

    <main class="d-flex flex-nowrap">
      <%- include('../Components/sidebar.ejs', { currentPage: "printers",
      username: username }) %>

      <section class="w-100">
        <%- include('../Components/navbar.ejs') %>

        <div class="container mt-4">
            <h2>Edit Printer: <%= obj.name %></h2>
            <form action="/dashboard/printers/update/<%= obj._id %>" method="POST" class="row g-3 shadow p-4 rounded bg-body-tertiary">
              <div class="col-md-6">
                <label class="form-label">Printer Name</label>
                <input name="name" value="<%= obj.name %>" type="text" class="form-control" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">Model</label>
                <input name="model" value="<%= obj.model %>" type="text" class="form-control" />
              </div>
              <div class="col-md-4">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                  <option value="active" <%= obj.status === 'active' ? 'selected' : '' %>>Active</option>
                  <option value="maintenance" <%= obj.status === 'maintenance' ? 'selected' : '' %>>Maintenance</option>
                  <option value="out_of_service" <%= obj.status === 'out_of_service' ? 'selected' : '' %>>Out of Service</option>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Counter (Pages)</label>
                <input name="counter" value="<%= obj.counter %>" type="number" class="form-control" />
              </div>
              <div class="col-md-4">
                  <label class="form-label">IP Address</label>
                  <input name="ipAddress" value="<%= obj.ipAddress %>" type="text" class="form-control" />
              </div>
              <div class="col-12 mt-4">
                <button type="submit" class="btn btn-primary">Update Printer</button>
                <a href="/dashboard/printers" class="btn btn-secondary">Cancel</a>
              </div>
            </form>
          </div>
      </section>
    </main>

    <script src="/js/bootstrap.bundle.min.js"></script>
    <script src="/js/sidebars.js"></script>
  </body>
</html>
